// ここに追加したいJavaScript、jQueryを記入してください。

jQuery(function($) {

  // =============================
  // 1. スマホメニューのカスタマイズ
  // =============================
  function yuzanCustomizeMenu() {
    var menuDrawer = document.querySelector('.menu-drawer');
    if (!menuDrawer) return false;

    if (menuDrawer.getAttribute('data-yuzan-customized') === 'true') return true;

    // 見出しのリンク無効化（CATEGORY, TAG, SEARCH）
    var headerTexts = ['CATEGORY', 'TAG', 'SEARCH'];
    var topLinks = menuDrawer.querySelectorAll(':scope > li > a');

    topLinks.forEach(function(link) {
      var text = link.textContent.trim();
      if (headerTexts.indexOf(text) !== -1) {
        var span = document.createElement('span');
        span.className = 'yuzan-menu-header';
        span.textContent = text;
        link.parentNode.replaceChild(span, link);
      }
    });

    // TAGの下にタグリストを挿入
    var tagMenuItem = document.querySelector('#menu-item-146');
    if (tagMenuItem && !tagMenuItem.querySelector('.yuzan-menu-tag-list')) {
      var tagListDiv = document.createElement('div');
      tagListDiv.className = 'yuzan-menu-tag-list';
      var myTags = [
        { name: 'リール', url: '/tag/リール/' },
        { name: 'ロッド', url: '/tag/ロッド/' },
        { name: 'トレイルラン', url: '/tag/トレイルラン/' },
        { name: '登山', url: '/tag/登山/' },
        { name: 'キャンプ', url: '/tag/キャンプ/' },
        { name: '渓流釣り', url: '/tag/渓流釣り/' }
      ];
      myTags.forEach(function(tag) {
        var clone = document.createElement('a');
        clone.href = tag.url;
        clone.className = 'yuzan-cloned-tag';
        clone.textContent = tag.name;
        tagListDiv.appendChild(clone);
      });
      tagMenuItem.appendChild(tagListDiv);
    }

    // SEARCHの下に検索窓を挿入
    var searchMenuItem = document.querySelector('#menu-item-147');
    if (searchMenuItem && !searchMenuItem.querySelector('.yuzan-menu-search-box')) {
      var searchDiv = document.createElement('div');
      searchDiv.className = 'yuzan-menu-search-box';
      searchDiv.innerHTML =
        '<form role="search" method="get" class="search-form" action="/">' +
          '<input type="search" class="search-field" placeholder="記事を検索..." value="" name="s">' +
          '<button type="submit" class="search-submit">' +
            '<span class="fa fa-search"></span>' +
          '</button>' +
        '</form>';
      searchMenuItem.appendChild(searchDiv);
    }

    menuDrawer.setAttribute('data-yuzan-customized', 'true');
    return true;
  }

  // =============================
  // 2. 波紋の色をカテゴリ別に設定
  // =============================
  function yuzanApplyRippleColors() {
    var cards = document.querySelectorAll('.entry-card-wrap, .new-entry-card-link, .popular-entry-card-link');
    cards.forEach(function(card) {
      var catLabel = card.querySelector('.cat-label, .new-entry-card-category, .popular-entry-card-category');
      if (catLabel) {
        var catText = catLabel.textContent.trim();
        var rippleColor = '149, 165, 166'; // デフォルト

        if (catText === '渓流釣り') {
          rippleColor = '0, 150, 255';
        } else if (catText === 'キャンプ') {
          rippleColor = '255, 120, 0';
        } else if (catText === '登山') {
          rippleColor = '0, 210, 100';
        }
        card.style.setProperty('--cat-ripple-color', rippleColor);
      }
    });
  }

  // =============================
  // 3. フッターロゴにリンクを挿入
  // =============================
  function yuzanInsertFooterLogo() {
    if ($('.navi-footer-in').length && !$('.yuzan-footer-logo-link').length) {
      var logoHtml = '<a href="/" class="yuzan-footer-logo-link"><img src="https://yuzan-life.com/wp-content/uploads/2026/04/cropped-yuazzn-icon.png" alt="HOME"></a>';
      $('.navi-footer-in').prepend(logoHtml);
    }
  }

  // 実行制御（ページ読み込み時など）
  yuzanApplyRippleColors();
  
  $(window).on('load', function() {
    yuzanCustomizeMenu();
    yuzanApplyRippleColors();
    yuzanInsertFooterLogo();
  });

  // メニュー用予備実行
  if (!yuzanCustomizeMenu()) {
    setTimeout(yuzanCustomizeMenu, 500);
  }

}); 

// このJavaScriptファイルは、親テーマのJavaScriptファイルのあとに呼び出されます。
