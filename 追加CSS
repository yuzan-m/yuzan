/* =========================================================
   26. Table of Contents (Numbered H2 & Bordered)
   ========================================================= */
.toc {
  background-color: #f2f2f2 !important;
  border: none !important;
  padding: 15px 25px 15px 25px !important;
  margin: 0 0 30px 0 !important;
}
.toc-title {
  font-family: 'Arial Black', sans-serif !important;
  font-weight: 900 !important;
  font-size: 1.1rem !important;
  color: #1a1a1a !important;
  text-align: center !important;
  margin-bottom: 10px !important;
  padding-bottom: 8px !important;
  border-bottom: 2px solid #1a1a1a !important;
}

/* 本文の箇条書きデザイン（27番）の干渉を完全にブロック */
.article .toc-content ul, 
.article .toc-content ol {
  margin: 0 !important;
  padding: 0 !important;
  border: none !important;
  background: transparent !important;
  list-style: none !important;
}

/* リスト項目のデフォルト設定 */
.article .toc-content li {
  margin: 0 !important;
  padding: 0 !important;
  border: none !important;
  background: transparent !important;
  line-height: 1.4 !important;
}

.article .toc-content li::before {
  content: none !important;
}

/* ★ ナンバリング用のカウンターをセット ★ */
.article .toc-content > .toc-list {
  counter-reset: toc-h2-counter !important;
}

/* H2項目（一番上の階層）の設定 */
.article .toc-content > .toc-list > li {
  border-top: 1px solid #e0e0e0 !important;
  padding: 12px 0 12px 34px !important; /* 左側に番号を入れる余白(34px)を確保 */
  position: relative !important;
  counter-increment: toc-h2-counter !important; /* 番号を1ずつ増やす */
}
.article .toc-content > .toc-list > li:first-child {
  border-top: none !important;
}

/* ★ H2のナンバリングデザイン（黒四角＋白文字） ★ */
.article .toc-content > .toc-list > li::before {
  content: counter(toc-h2-counter) !important;
  position: absolute !important;
  left: 0 !important;
  top: 12px !important; /* H2テキストの高さに合わせる */
  width: 22px !important;
  height: 22px !important;
  background-color: #1a1a1a !important;
  color: #ffffff !important;
  font-family: 'Arial Black', sans-serif !important;
  font-size: 0.85rem !important;
  font-weight: 900 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  border-radius: 0 !important; /* 四角形にする */
}

/* 共通リンク設定 */
.article .toc-content a {
  display: inline !important; 
  color: #1a1a1a !important;
  text-decoration: none !important;
  font-size: 0.95rem !important;
}

/* H2（親要素）のリンクのみ太字にする */
.article .toc-content > .toc-list > li > a {
  font-weight: bold !important;
}

/* H3, H4（子要素）のリンクは太字にしない（通常体） */
.article .toc-content ul ul a,
.article .toc-content ol ol a {
  font-weight: normal !important;
}

.article .toc-content a:hover {
  opacity: 0.6 !important;
  text-decoration: underline !important;
}

/* 下の階層（H3, H4）の設定：余白とインデント */
.article .toc-content ul ul,
.article .toc-content ol ol {
  padding-left: 10px !important; /* H2テキストより少し右にズラす */
  margin-top: 6px !important;
}
.article .toc-content ul ul li,
.article .toc-content ol ol li {
  border: none !important;
  padding: 4px 0 !important; /* 上下の隙間 */
}

/* 子要素（H3, H4）には絶対に番号を出さない設定 */
.article .toc-content ul ul li::before,
.article .toc-content ol ol li::before {
  content: none !important;
}

/* Cocoonデフォルトのナンバー（数字）を非表示 */
.toc-list .toc-list-number {
  display: none !important;
}

/* =========================================================
   27. List Design (UL, OL) with Gray Background
   ========================================================= */
.article ul, .article ol {
  padding: 0 !important;
  margin: 30px 0 !important;
}

/* Base style for both list types */
.article ul li, .article ol li {
  padding: 10px 15px !important; /* 内側の余白 */
  margin: 0 !important; /* 隙間をなくしてくっつける */
  line-height: 1.6;
  position: relative;
  /* グレーの背景（ストライプではなく均一なグレー） */
  background-color: #f2f2f2 !important; 
  /* リスト同士の境界線 */
  border-bottom: 1px solid #e0e0e0 !important; 
}

/* 最後のアイテムの境界線を消す */
.article ul li:last-child, .article ol li:last-child {
  border-bottom: none !important;
}

/* Bullet list (UL) */
.article ul li {
  list-style: none !important;
  padding-left: 1.8em !important; /* ドット用の左余白 */
}

.article ul li::before {
  content: "";
  position: absolute;
  left: 0.6em; /* 左端から少し離す */
  top: 50%; /* 上下中央 */
  transform: translateY(-50%); /* ビシッと中央に */
  width: 6px;
  height: 6px;
  background: #1a1a1a; /* 四角いドットでシャープに */
}

/* Number list (OL) */
.article ol li {
  list-style-position: inside !important; /* 番号を内側に */
  font-weight: bold;
}

/* =========================================================
   28. Blockquote (引用) with Solid Design
   ========================================================= */
.article blockquote {
  background: #f2f2f2 !important; /* 全体をグレー背景に */
  border-left: 4px solid #1a1a1a !important; /* 左側の黒線 */
  margin: 30px 0 !important;
  padding: 20px 30px !important;
  color: #1a1a1a !important;
  font-style: italic;
  font-family: inherit !important;
  border-radius: 0 !important; /* 角丸を排除 */
}

/* アイコンフォントのエラーを避けるため、引用アイコン（before）を非表示に */
.article blockquote::before, .article blockquote::after {
  content: none !important;
}

/* =========================================================
   29. Information Box (案内ボックス)
   ========================================================= */
/* Cocoonの「白抜き」「案内」等のボックスを上書き */
.blank-box, .common-box {
  border: 1px solid #1a1a1a !important;
  background-color: #fff !important;
  border-radius: 0 !important; /* 角丸を排除 */
  padding: 20px !important;
  margin: 30px 0 !important;
}

/* グレー背景のシンプルボックス */
.gray-box {
  background-color: #f2f2f2 !important;
  border: none !important;
  padding: 20px !important;
  margin: 30px 0 !important;
}

/* =========================================================
   30. Speech Bubble (吹き出し - 全幅＆拡大版)
   ========================================================= */
.speech-balloon {
  margin-bottom: 30px !important;
  border: none !important;
  box-shadow: none !important;
  box-sizing: border-box !important;
  display: flex !important;
  align-items: flex-start !important;
  width: 100% !important; /* 全幅を強制 */
  max-width: 100% !important;
}

/* 右向き・左向きのレイアウト制御 */
.speech-balloon-left { flex-direction: row !important; }
.speech-balloon-right { flex-direction: row-reverse !important; }

/* 三角の残骸を完全に消去 */
.speech-balloon::before, .speech-balloon::after,
.speech-content::before, .speech-content::after {
  display: none !important;
  content: none !important;
}

/* アイコンコンテナ（サイズを100pxで絶対に固定） */
.speech-person {
  flex: 0 0 100px !important; /* 横幅が潰れないようロック */
  width: 100px !important;
  text-align: center !important;
}
.speech-balloon-left .speech-person {
  margin-right: 20px !important;
  margin-left: 0 !important;
}
.speech-balloon-right .speech-person {
  margin-left: 20px !important;
  margin-right: 0 !important;
}

/* アイコン画像（強制的に100pxに拡大） */
.speech-person img {
  width: 100px !important;
  height: 100px !important;
  border-radius: 50% !important;
  object-fit: cover !important;
  border: none !important;
  box-shadow: none !important;
  display: block !important;
  margin: 0 auto !important;
}

/* メンバー名 */
.speech-name {
  font-size: 0.8rem !important;
  font-weight: bold !important;
  color: #1a1a1a !important;
  margin-top: 8px !important;
  line-height: 1.2 !important;
}

/* テキストエリア（残りの画面幅を100%使い切る） */
.speech-content {
  background-color: #f2f2f2 !important;
  border: none !important;
  border-radius: 0 !important;
  color: #1a1a1a !important;
  flex: 1 1 auto !important; /* 余白をすべて吸収 */
  min-width: 0 !important;
  width: 100% !important;
  max-width: none !important; /* Cocoonデフォルトの幅制限を完全解除 */
  padding: 20px !important;
  margin: 0 !important;
  box-sizing: border-box !important;
}

/* =========================================================
   31. Internal Blog Card (関連記事)
   ========================================================= */
.blogcard {
  border: 1px solid #e0e0e0 !important;
  border-radius: 0 !important;
  padding: 10px !important;
  transition: all 0.3s ease;
}

.blogcard:hover {
  background-color: #f9f9f9 !important;
  border-color: #1a1a1a !important;
}

.blogcard-title {
  font-weight: 900 !important;
  line-height: 1.4 !important;
}

/* =========================================================
   32. Article Responsive Adjustments (SP)
   ========================================================= */
@media screen and (max-width: 768px) {
  /* ① H2のサイズ・余白調整 */
  .article h2 {
    font-size: 1.15rem !important; /* 担当者様ご指定のサイズ */
    padding: 8px 12px !important; /* 余白を詰める */
    margin: 25px 0 10px 0 !important;
  }

  /* ② 吹き出しの全幅化・親要素の余白を突破・アイコン拡大維持 */
  .speech-balloon {
    margin-bottom: 25px !important;
    /* ★ 親要素の左右の余白（約15px〜20px）を無視して画面端まで広げる裏技 */
    margin-left: -15px !important;
    margin-right: -15px !important;
    padding-left: 15px !important;  /* アイコンが画面端に張り付かないように内側へ戻す */
    padding-right: 15px !important; /* テキストが画面端に張り付かないように内側へ戻す */
    width: calc(100% + 30px) !important; /* マイナスした分だけ全体の幅を広げる */
    max-width: none !important;
  }
  
  .speech-person {
    flex: 0 0 75px !important; /* スマホは75pxでロック（維持） */
    width: 75px !important;
  }
  .speech-balloon-left .speech-person { margin-right: 15px !important; }
  .speech-balloon-right .speech-person { margin-left: 15px !important; }

  .speech-person img {
    width: 75px !important;
    height: 75px !important;
  }
  
  .speech-content {
    padding: 15px !important;
    font-size: 0.95rem !important;
  }
	
/* ===========================================
   33. Manga Carousel (縦型漫画スライダー - 完全版)
   ===========================================*/

/* カルーセルエリア全体の背景・余白 */
.carousel {
  background-color: transparent !important; 
  padding: 20px 0 40px 0 !important;
  margin-bottom: 40px !important;
}

/* カルーセルカード全体 */
.carousel-entry-card {
  border-radius: 0 !important;
  box-shadow: none !important;
  background: transparent !important;
  padding: 0 10px !important; 
  display: flex !important;
  flex-direction: column !important;
}

/* ★ 1. 画像の「枠」をご指定の比率（1055:1491）に絶対固定 ★ */
.carousel-entry-card-thumb {
  padding-top: 141.32% !important; /* 1055:1491の比率 */
  padding-bottom: 0 !important; 
  height: 0 !important;
  width: 100% !important;
  border-radius: 0 !important;
  overflow: hidden !important;
  margin: 0 !important;
  order: 1 !important; 
  background: transparent !important;
  position: relative !important; 
}

/* ★ 2. 復元されたオリジナル画像が枠をピッタリ埋め尽くす ★ */
.carousel-entry-card-thumb img {
  position: absolute !important;
  top: 0 !important;
  left: 0 !important;
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important; /* オリジナル画像が来るので綺麗に埋まります！ */
  transition: transform 0.3s ease !important;
}

/* ホバー時のズームアクション */
.carousel-entry-card:hover .carousel-entry-card-thumb img {
  transform: scale(1.05) !important;
}

/* カテゴリーラベルを完全に消す */
.carousel-entry-card-thumb .cat-label,
.carousel-entry-card-thumb .ribbon {
  display: none !important;
}

/* テキストエリア全体の調整 */
.carousel-entry-card-content {
  order: 2 !important; 
  display: flex !important;
  flex-direction: column !important;
  padding: 12px 0 0 0 !important; 
  background: transparent !important;
}

/* 日付とタイトルのデザイン */
.carousel-entry-card-meta {
  order: 1 !important;
  margin-bottom: 4px !important;
  display: block !important;
}
.carousel-entry-card-meta .post-date {
  font-size: 0.8rem !important; 
  color: #888888 !important; 
  font-family: 'Courier New', Consolas, monospace !important;
  font-weight: bold !important;
}
.carousel-entry-card-meta .post-date::before {
  display: none !important;
}

.carousel-entry-card-title {
  order: 2 !important;
  font-size: 1.05rem !important; 
  font-weight: 900 !important;
  color: #1a1a1a !important;
  line-height: 1.4 !important;
  margin: 0 !important;
  display: -webkit-box !important;
  -webkit-box-orient: vertical !important;
  -webkit-line-clamp: 2 !important; 
  overflow: hidden !important;
  text-align: center !important; 
}

/* スマホ用の余白調整 */
@media screen and (max-width: 768px) {
  .carousel {
    padding: 10px 0 30px 0 !important;
    margin-bottom: 30px !important;
  }
}
